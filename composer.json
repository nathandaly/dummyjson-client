{
    "name": "natedaly/dummyjson-client",
    "description": "A simple PHP API client for DummyJSON that provides an easy, framework-independent way to fetch placeholder user data.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Natedaly\\DummyjsonClient\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Nate Daly",
            "email": "justlikephp@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "8.0.x-dev"
    },
    "require-dev": {
        "phpstan/phpstan": "2.2.x-dev",
        "phpstan/phpstan-strict-rules": "2.0.x-dev",
        "laravel/pint": "dev-main"
    }
}
