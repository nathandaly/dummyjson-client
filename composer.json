{
    "name": "natedaly/dummyjson-client",
    "description": "A simple PHP API client for DummyJSON that provides an easy, framework-independent way to fetch placeholder user data.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Natedaly\\DummyjsonClient\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Nate Daly",
            "email": "justlikephp@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.10"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "pestphp/pest": "^4.6",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse",
        "check": [
            "@format:test",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
